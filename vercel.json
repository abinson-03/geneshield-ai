{
  "services": {
    "frontend": {
      "root": "frontend"
    },
    "backend": {
      "root": "backend",
      "entrypoint": "src/server.js"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "backend/api/$1"
    },
    {
      "source": "/((?!api|assets|.*\\.).*)",
      "destination": "frontend/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "frontend/$1"
    }
  ]
}
