{
  "version": 2,
  "services": {
    "frontend": {
      "root": "frontend"
    },
    "backend": {
      "root": "backend",
      "entrypoint": "src/server.js"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": {
        "service": "backend"
      }
    },
    {
      "source": "/assets/(.*)",
      "destination": {
        "service": "frontend",
        "path": "/assets/$1"
      }
    },
    {
      "source": "/(.*\\.(js|css|ico|png|svg|woff|woff2|ttf|map))",
      "destination": {
        "service": "frontend"
      }
    },
    {
      "source": "/(.*)",
      "destination": {
        "service": "frontend",
        "path": "/index.html"
      }
    }
  ]
}
