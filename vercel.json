{
  "version": 2,
  "services": {
    "frontend": {
      "root": "frontend"
    },
    "backend": {
      "root": "backend",
      "entrypoint": "src/server.js"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": {
        "service": "backend"
      }
    },
    {
      "source": "/assets/:path*",
      "destination": {
        "service": "frontend",
        "path": "/assets/:path*"
      }
    },
    {
      "source": "/:path*",
      "destination": {
        "service": "frontend",
        "path": "/index.html"
      }
    }
  ]
}
