{
  "version": 2,
  "services": {
    "frontend": {
      "root": "frontend"
    },
    "backend": {
      "root": "backend",
      "entrypoint": "src/server.js"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": {
        "service": "backend"
      }
    },
    {
      "source": "/assets/:path*",
      "destination": {
        "service": "frontend"
      }
    },
    {
      "source": "/index.html",
      "destination": {
        "service": "frontend"
      }
    },
    {
      "source": "/:path((?!api|assets|index\\.html).*)",
      "destination": "/index.html"
    }
  ]
}
